{
  "manifest_version": 3,
  "name": "Music Widget Bridge",
  "version": "4.0",
  "description": "Виджет музыки для OBS — показывает текущий трек из браузера",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:9876/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
