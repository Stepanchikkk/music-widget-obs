{
  "manifest_version": 3,
  "name": "Music Widget OBS",
  "version": "2.1.0",
  "description": "Отображает название и статус текущего трека в OBS. github.com/Stepanchikkk/music-widget-obs",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["preview.html", "widget.js", "styles/*.js", "digital-cyrillic.otf", "stereo-bg.png"],
    "matches": ["<all_urls>"]
  }]
}
